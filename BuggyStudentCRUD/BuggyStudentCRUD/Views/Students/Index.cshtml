@model IEnumerable<BuggyStudentCRUD.Models.Student>

@{
    ViewData["Title"] = "Students";
}

<h2><i class="fas fa-users"></i> Student Records</h2>
<hr />

<div class="row mb-3">
    <div class="col-md-6">
        <form asp-action="Index" method="get" class="d-flex">
            <input type="text" name="searchString" value="@ViewData["CurrentFilter"]"
                   class="form-control me-2" placeholder="Search by name or course..." />
            <button type="submit" class="btn btn-outline-primary">
                <i class="fas fa-search"></i> Search
            </button>
        </form>
    </div>
    <div class="col-md-6 text-end">
        <a asp-action="Create" class="btn btn-success">
            <i class="fas fa-plus"></i> Add New Student
        </a>
    </div>
</div>

<table class="table table-striped table-hover shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewData["NameSortParam"]"
                   asp-route-searchString="@ViewData["CurrentFilter"]" class="text-white text-decoration-none">
                    <i class="fas fa-sort"></i> Name
                </a>
            </th>
            <th>Email</th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewData["CourseSortParam"]"
                   asp-route-searchString="@ViewData["CurrentFilter"]" class="text-white text-decoration-none">
                    <i class="fas fa-sort"></i> Course
                </a>
            </th>
            <th>Year</th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewData["GPASortParam"]"
                   asp-route-searchString="@ViewData["CurrentFilter"]" class="text-white text-decoration-none">
                    <i class="fas fa-sort"></i> GPA
                </a>
            </th>
            <th>Enrolled</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.FullName</td>
                <td>@item.Email</td>
                <td>@item.Course</td>
                <td>@item.YearLevel</td>
                <td>
                    <span class="badge @(item.GPA >= 3.5 ? "bg-success" : item.GPA >= 2.5 ? "bg-warning text-dark" : "bg-danger")">
                        @item.GPA.ToString("F2")
                    </span>
                </td>
                <td>@item.EnrollmentDate.ToString("MMM dd, yyyy")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white" title="Details">
                        <i class="fas fa-eye"></i>
                    </a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Edit">
                        <i class="fas fa-edit"></i>
                    </a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" title="Delete">
                        <i class="fas fa-trash"></i>
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <div class="alert alert-info text-center">
        <i class="fas fa-info-circle"></i> No students found. Try a different search or add a new student.
    </div>
}
