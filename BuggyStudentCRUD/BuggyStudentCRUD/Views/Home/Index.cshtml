@{
    ViewData["Title"] = "Home";
}

<div class="text-center mt-4">
    <h1 class="display-4"><i class="fas fa-graduation-cap"></i> Student Records Management</h1>
    <p class="lead mt-3">A simple CRUD application for managing student records.</p>
    <hr />
    <div class="row mt-5">
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <i class="fas fa-list fa-3x text-primary mb-3"></i>
                    <h5 class="card-title">View Students</h5>
                    <p class="card-text">Browse all student records with search and sort capabilities.</p>
                    <a asp-controller="Students" asp-action="Index" class="btn btn-primary">
                        <i class="fas fa-arrow-right"></i> Go to List
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <i class="fas fa-user-plus fa-3x text-success mb-3"></i>
                    <h5 class="card-title">Add Student</h5>
                    <p class="card-text">Register a new student into the system database.</p>
                    <a asp-controller="Students" asp-action="Create" class="btn btn-success">
                        <i class="fas fa-plus"></i> Add New
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <i class="fas fa-info-circle fa-3x text-info mb-3"></i>
                    <h5 class="card-title">About</h5>
                    <p class="card-text">Learn more about this practical lab activity and objectives.</p>
                    <a asp-controller="Home" asp-action="About" class="btn btn-info text-white">
                        <i class="fas fa-book"></i> Read More
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
