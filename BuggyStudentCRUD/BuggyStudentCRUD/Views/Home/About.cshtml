@{
    ViewData["Title"] = "About";
}

<div class="mt-4">
    <h2><i class="fas fa-info-circle"></i> About This Lab Activity</h2>
    <hr />
    <div class="card shadow-sm mt-3">
        <div class="card-body">
            <h5 class="card-title">Practical Lab: Bug Hunting in ASP.NET Core MVC</h5>
            <p class="card-text">
                This application is a <strong>Student Records Management System</strong> built with ASP.NET Core MVC
                and Entity Framework Core. It was intentionally developed with several bugs for you to find and fix.
            </p>
            <h6 class="mt-3">Your Objectives:</h6>
            <ul>
                <li>Clone the repository and run the application</li>
                <li>Test all CRUD operations (Create, Read, Update, Delete)</li>
                <li>Identify the bugs by observing incorrect behavior</li>
                <li>Fix each bug and document what was wrong</li>
                <li>Submit your corrected code with a summary of bugs found</li>
            </ul>
            <h6 class="mt-3">Technology Stack:</h6>
            <ul>
                <li>ASP.NET Core 6.0 MVC</li>
                <li>Entity Framework Core (In-Memory Database)</li>
                <li>Bootstrap 5</li>
                <li>C#</li>
            </ul>
        </div>
    </div>
</div>
